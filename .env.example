# ==============================================================================
# InviteOnly Network - Environment Configuration Template
# Copy this file to '.env' and fill in your target credentials.
# ==============================================================================

# 1. Database Connection (Required for database/migrate.js)
# PostgreSQL connection string: postgres://<user>:<password>@<host>:<port>/<database>
# E.g. for local Docker: postgres://postgres:securepassword123@localhost:5432/review_network
# E.g. for Supabase: postgres://postgres.yourproject:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgres://postgres:securepassword123@localhost:5432/review_network"

# 2. Supabase Integration (Required for frontend and worker execution)
# Find these in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-secret-supabase-service-role-key"

# 3. Cloudflare Deployment (Required for Cloudflare edge worker wrangler scripts)
# Find your account ID in Cloudflare dashboard side panel
# Generate API Token with Edit Workers permissions in My Profile -> API Tokens
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-workers-api-token"

# 4. Client Simulator server Configuration (Optional)
PORT=8080
